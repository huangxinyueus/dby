<style>
html,body{height:100%;margin:0;background:url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 800"><rect fill="%23ffeef7" width="1200" height="800"/><circle cx="150" cy="200" r="80" fill="%23ffd1e2" opacity="0.6"/><circle cx="1000" cy="600" r="120" fill="%23c1f5ff" opacity="0.5"/><circle cx="900" cy="150" r="60" fill="%23d0c5ff" opacity="0.7"/></svg>') center/cover;font-family:"Helvetica Neue",Arial,"Noto Sans SC",sans-serif;}
